rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == 'archive-v1';
      allow write: if request.auth != null && request.auth.uid == 'archive-v1'
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
